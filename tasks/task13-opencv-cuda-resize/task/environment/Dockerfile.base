# OpenCV CUDA base 镜像
# 构建命令:
#   DOCKER_BUILDKIT=1 docker build \
#     -t opencv-cuda-base -f tasks/task13-opencv-cuda-resize/task/environment/Dockerfile.base .

FROM nvidia/cuda:12.2.0-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# 安装 Python 和依赖
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-dev \
    build-essential cmake git curl \
    libgtk-3-dev libavcodec-dev libavformat-dev libswscale-dev \
    libtbb-dev libjpeg-dev libpng-dev libtiff-dev \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python

# 克隆 OpenCV 源码
RUN git clone --depth 1 --branch 4.9.0 https://github.com/opencv/opencv.git /build/opencv && \
    git clone --depth 1 --branch 4.9.0 https://github.com/opencv/opencv_contrib.git /build/opencv_contrib

# 构建 OpenCV with CUDA support
RUN mkdir -p /build/opencv/build && \
    cd /build/opencv/build && \
    cmake -D CMAKE_BUILD_TYPE=Release \
          -D CMAKE_INSTALL_PREFIX=/usr/local \
          -D OPENCV_EXTRA_MODULES_PATH=/build/opencv_contrib/modules \
          -D WITH_CUDA=ON \
          -D CUDA_ARCH_BIN="6.0,7.0,7.5,8.0,8.6,8.9,9.0" \
          -D WITH_CUBLAS=ON \
          -D ENABLE_FAST_MATH=ON \
          -D CUDA_FAST_MATH=ON \
          -D WITH_TBB=ON \
          -D WITH_V4L=OFF \
          -D WITH_GTK=ON \
          -D BUILD_opencv_python3=ON \
          -D PYTHON3_EXECUTABLE=/usr/bin/python3 \
          -D BUILD_TESTS=OFF \
          -D BUILD_PERF_TESTS=OFF \
          -D BUILD_EXAMPLES=OFF \
          .. 2>&1 | tail -5 && \
    make -j$(nproc) 2>&1 | tail -5 && \
    make install 2>&1 | tail -3 && \
    ldconfig

# Install numpy (required for cv2 python bindings)
RUN pip install --no-cache-dir numpy

# 验证
RUN python -c "import cv2; print(f'OpenCV {cv2.__version__}'); print(f'CUDA devices: {cv2.cuda.getCudaEnabledDeviceCount()}')"

CMD ["/bin/bash"]
